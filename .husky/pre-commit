echo "Running pre-commit checks for frontend..."

# Run linting
pnpm lint
if [ $? -ne 0 ]; then
  echo "Linting failed. Fix linting errors before committing."
  exit 1
fi

# Run typecheck
pnpm typecheck
if [ $? -ne 0 ]; then
  echo "Typecheck failed. Fix type errors before committing."
  exit 1
fi

# Run tests with coverage
echo "Running tests with coverage..."
pnpm test:coverage
if [ $? -ne 0 ]; then
  echo "Tests failed. Fix tests before committing."
  exit 1
fi

# Check coverage thresholds
echo "Checking coverage thresholds..."
if [ ! -f coverage/index.html ]; then
  echo "Coverage report not found. Please run tests with coverage."
  exit 1
fi

# Extract coverage percentages from the coverage summary
STATEMENTS_COVERAGE=$(grep -A 10 "All files" coverage/index.html | grep -E "[0-9]+\.[0-9]+%" | head -1 | sed 's/[^0-9.]//g' | cut -d. -f1)
BRANCHES_COVERAGE=$(grep -A 15 "All files" coverage/index.html | grep -E "[0-9]+\.[0-9]+%" | head -2 | tail -1 | sed 's/[^0-9.]//g' | cut -d. -f1)
FUNCTIONS_COVERAGE=$(grep -A 20 "All files" coverage/index.html | grep -E "[0-9]+\.[0-9]+%" | head -3 | tail -1 | sed 's/[^0-9.]//g' | cut -d. -f1)
LINES_COVERAGE=$(grep -A 25 "All files" coverage/index.html | grep -E "[0-9]+\.[0-9]+%" | head -4 | tail -1 | sed 's/[^0-9.]//g' | cut -d. -f1)

# Check if coverage meets thresholds (70% for statements, functions, and lines; 50% for branches)
if [ "$STATEMENTS_COVERAGE" -lt 70 ] || [ "$BRANCHES_COVERAGE" -lt 50 ] || [ "$FUNCTIONS_COVERAGE" -lt 70 ] || [ "$LINES_COVERAGE" -lt 70 ]; then
  echo "Coverage thresholds not met. Please improve test coverage."
  echo "Current coverage: Statements=$STATEMENTS_COVERAGE%, Branches=$BRANCHES_COVERAGE%, Functions=$FUNCTIONS_COVERAGE%, Lines=$LINES_COVERAGE%"
  exit 1
fi

echo "Coverage thresholds met!"
echo "All pre-commit checks passed!"
